rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().data.role == 'admin';
    }

    function validUserCreate() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.role in ['participant', 'admin'];
    }

    function validMatchData() {
      return request.resource.data.home is string
        && request.resource.data.away is string
        && request.resource.data.kickoff is string
        && (request.resource.data.homeScore == null || request.resource.data.homeScore is int)
        && (request.resource.data.awayScore == null || request.resource.data.awayScore is int);
    }

    function validPredictionData() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.matchId is string
        && request.resource.data.home is int
        && request.resource.data.away is int;
    }

    function validWinnerPredictionData() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.roundId in ['r16', 'r8', 'qf', 'sf', 'final']
        && request.resource.data.team is string;
    }

    function validWinnerSettings() {
      return request.resource.data.deadline is string
        && request.resource.data.activeRound in ['r16', 'r8', 'qf', 'sf', 'final']
        && request.resource.data.actualWinner is string
        && request.resource.data.teamsByRound is map;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && validUserCreate();
      allow update: if isOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() && validMatchData();
    }

    match /predictions/{predictionId} {
      allow read: if signedIn();
      allow create: if signedIn() && validPredictionData();
      allow update: if signedIn() && resource.data.userId == request.auth.uid && validPredictionData();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /winnerPredictions/{predictionId} {
      allow read: if signedIn();
      allow create: if signedIn() && validWinnerPredictionData();
      allow update: if signedIn() && resource.data.userId == request.auth.uid && validWinnerPredictionData();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() && docId == 'winnerTournament' && validWinnerSettings();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}